# FFP 家庭财务规划系统 - 环境配置模板
# 复制此文件为 .env.dev, .env.test, .env.prod 并根据需要修改

# ========================================
# 环境标识
# ========================================
ENV=dev
NODE_ENV=development

# ========================================
# 服务端口配置（使用高位端口避免冲突）
# ========================================
# 后端 API 端口（暴露到宿主机）
BACKEND_PORT=57200

# 前端 Web 端口（暴露到宿主机）
FRONTEND_PORT=53000

# MySQL 数据库端口（不暴露到宿主机，仅 Docker 网络内部访问）
# 容器内访问: mysql:3306

# ========================================
# 数据库配置
# ========================================
MYSQL_ROOT_PASSWORD=rootpassword
MYSQL_DATABASE=ffp
MYSQL_USER=user
MYSQL_PASSWORD=password

# 数据库连接 URL（本地开发使用 localhost，生产/Docker 使用 mysql:3306）
DATABASE_URL="mysql://${MYSQL_USER}:${MYSQL_PASSWORD}@mysql:3306/${MYSQL_DATABASE}"

# ========================================
# 后端配置
# ========================================
# JWT 密钥（生产环境请使用强随机密钥）
JWT_SECRET=your-secret-key-change-in-production
JWT_ACCESS_EXPIRATION=3600
JWT_REFRESH_EXPIRATION=604800

# CORS 配置
CORS_ORIGIN=http://localhost:${FRONTEND_PORT}

# 日志级别 (debug, info, warn, error)
LOG_LEVEL=debug

# ========================================
# 前端配置
# ========================================
# API 服务地址
VITE_API_URL=http://localhost:${BACKEND_PORT}/api/v1

# ========================================
# Docker 配置
# ========================================
# 容器名称前缀
COMPOSE_PROJECT_NAME=ffp-${ENV}

# ========================================
# 开发工具配置
# ========================================
# 是否启用热重载（开发环境）
HOT_RELOAD=true

# 是否启用调试模式
DEBUG=false
